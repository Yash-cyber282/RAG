# ── Ollama (fully local LLM — no API key needed!) ─────────────────────────────
# Install: https://ollama.com/download
# Pull model: ollama pull llama3.2
# Start server: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Other good models to try:
#   ollama pull mistral
#   ollama pull phi3
#   ollama pull gemma2
#   ollama pull deepseek-r1

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=                  # leave blank to use default
CHROMA_COLLECTION_NAME=rag_documents

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
BATCH_SIZE=100

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K_DENSE=10
TOP_K_BM25=10
TOP_K_RERANK=5

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=86400
