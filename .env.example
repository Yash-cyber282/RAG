# ── Anthropic Claude API ───────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # fast & affordable; swap for claude-sonnet-4-6 for higher quality

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=                  # leave blank to use default
CHROMA_COLLECTION_NAME=rag_documents

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
BATCH_SIZE=100

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K_DENSE=10
TOP_K_BM25=10
TOP_K_RERANK=5

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=86400
