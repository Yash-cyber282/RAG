# ── Local LLM (HuggingFace Transformers — no API key, no Ollama!) ─────────────
# Model downloads automatically on first run and is cached locally.
#
# CPU-friendly options (recommended to start):
#   google/flan-t5-base    ~250MB  fast
#   google/flan-t5-large   ~800MB  better quality
#
# GPU options (requires CUDA):
#   google/flan-t5-xl      ~3GB
#   mistralai/Mistral-7B-Instruct-v0.3   ~14GB
#
HF_MODEL=google/flan-t5-base

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=
CHROMA_COLLECTION_NAME=rag_documents

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
BATCH_SIZE=100

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K_DENSE=10
TOP_K_BM25=10
TOP_K_RERANK=5

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=86400
